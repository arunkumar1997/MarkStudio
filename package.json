{
  "name": "markstudio",
  "displayName": "MarkStudio",
  "description": "A native, Obsidian-inspired Markdown editor for Visual Studio Code.",
  "version": "0.0.1",
  "publisher": "markstudio",
  "license": "MIT",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "editor",
    "preview",
    "custom editor"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "markstudio.editor",
        "displayName": "MarkStudio",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "markstudio.openMarkStudio",
        "title": "Open in MarkStudio",
        "category": "MarkStudio",
        "enablement": "editorLangId == markdown"
      },
      {
        "command": "markstudio.layout.showSplit",
        "title": "Show Editor and Preview",
        "category": "MarkStudio"
      },
      {
        "command": "markstudio.layout.showEditorOnly",
        "title": "Show Editor Only",
        "category": "MarkStudio"
      },
      {
        "command": "markstudio.layout.showPreviewOnly",
        "title": "Show Preview Only",
        "category": "MarkStudio"
      },
      {
        "command": "markstudio.togglePreview",
        "title": "Toggle Preview",
        "category": "MarkStudio"
      },
      {
        "command": "markstudio.toggleSplit",
        "title": "Toggle Split View",
        "category": "MarkStudio"
      },
      {
        "command": "markstudio.focusEditor",
        "title": "Focus Editor",
        "category": "MarkStudio"
      },
      {
        "command": "markstudio.focusPreview",
        "title": "Focus Preview",
        "category": "MarkStudio"
      }
    ],
    "keybindings": [
      {
        "command": "markstudio.togglePreview",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "activeCustomEditorId == 'markstudio.editor'"
      },
      {
        "command": "markstudio.toggleSplit",
        "key": "ctrl+k ctrl+v",
        "mac": "cmd+k cmd+v",
        "when": "activeCustomEditorId == 'markstudio.editor'"
      },
      {
        "command": "markstudio.focusEditor",
        "key": "ctrl+k ctrl+e",
        "mac": "cmd+k cmd+e",
        "when": "activeCustomEditorId == 'markstudio.editor'"
      },
      {
        "command": "markstudio.focusPreview",
        "key": "ctrl+k ctrl+r",
        "mac": "cmd+k cmd+r",
        "when": "activeCustomEditorId == 'markstudio.editor'"
      }
    ],
    "configuration": {
      "title": "MarkStudio",
      "properties": {
        "markstudio.editor.lineNumbers": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Show line numbers in the MarkStudio source editor."
        },
        "markstudio.editor.wordWrap": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Soft-wrap long lines in the MarkStudio source editor."
        },
        "markstudio.preview.math": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Render inline ($…$) and block ($$…$$) math in the MarkStudio preview with KaTeX."
        },
        "markstudio.preview.mermaid": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Render fenced ```mermaid code blocks as diagrams in the MarkStudio preview. The Mermaid library is lazy-loaded on first use."
        },
        "markstudio.preview.callouts": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Render callout / admonition blockquotes (e.g. > [!NOTE], > [!WARNING], > [!TIP]) as styled boxes in the MarkStudio preview."
        },
        "markstudio.preview.wikiLinks": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Render wiki-style links (e.g. [[note]], [[note|alias]], [[note#heading]]) as links in the MarkStudio preview."
        },
        "markstudio.preview.footnotes": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Render footnotes ([^1] references and [^1]: definitions) as linked footnotes in the MarkStudio preview."
        },
        "markstudio.preview.taskLists": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Render GFM task-list items (- [ ] / - [x]) as checkboxes in the MarkStudio preview. Checkboxes are read-only in the preview."
        },
        "markstudio.preview.tables": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Render GFM pipe tables in the MarkStudio preview."
        },
        "markstudio.preview.strikethrough": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Render ~~strikethrough~~ text in the MarkStudio preview."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "markstudio.outline",
          "name": "MarkStudio Outline",
          "when": "activeCustomEditorId == 'markstudio.editor'"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build -- --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "lint": "eslint . --max-warnings 0 && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "compile": "npm run typecheck && npm run build",
    "test:unit": "node esbuild.test.js && node --test dist-test/tests.cjs",
    "test:integration": "node esbuild.integration.js && node --test dist-test/integration.cjs",
    "test:exthost": "npm run build && node esbuild.exthost.js && node dist-test/exthost-runner.cjs",
    "test": "npm run typecheck:test && npm run test:unit && npm run test:integration "
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/language": "^6.10.2",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.28.0",
    "@lezer/highlight": "^1.2.0",
    "@vscode/markdown-it-katex": "^1.1.2",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "markdown-it-footnote": "^4.0.0",
    "mermaid": "^11.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jsdom": "^28.0.3",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.20.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.5",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.62.0"
  },
  "allowScripts": {
    "esbuild@0.20.2": true
  }
}
